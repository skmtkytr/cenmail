# Template for the local .env.op (not committed). Copy to .env.op and adjust
# the 1Password references to your own vault layout.
#
# Run the app with:  op run --env-file=.env.op -- pnpm app

CENMAIL_GOOGLE_CLIENT_ID=op://<Vault>/<Item>/client_id
CENMAIL_GOOGLE_CLIENT_SECRET=op://<Vault>/<Item>/client_secret
